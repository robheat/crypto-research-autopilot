# Venice API Key (required)
VENICE_API_KEY=your_venice_api_key_here

# Venice model to use for brief generation (optional, defaults to a capable model)
VENICE_MODEL=qwen/qwen3-235b-a22b-04-28

# CoinMarketCap API Key (optional — enables Fear & Greed index + sector rotation)
CMC_API_KEY=

# LunarCrush API Key (optional — enables social sentiment & narrative momentum)
LUNARCRUSH_API_KEY=

# Morning brief schedule (cron expression, e.g. "0 6 * * *" = 6am daily)
BRIEF_SCHEDULE_CRON=0 6 * * *

# Vault path (defaults to ./vault relative to project root)
VAULT_PATH=vault

# GitHub Personal Access Token (optional — publishes morning briefs to cryptocatalyst.news)
# Create one at https://github.com/settings/tokens with Contents: Read and Write
GITHUB_TOKEN=
GITHUB_REPO=robheat/cryptocatalyst-news
